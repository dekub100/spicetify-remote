			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/volume/volume-up",
					"TitleAlignment": "middle"
				}
			]
		},
		{
			"Name": "Volume Down",
			"UUID": "com.dekub.spicetify-remote.volumedown",
