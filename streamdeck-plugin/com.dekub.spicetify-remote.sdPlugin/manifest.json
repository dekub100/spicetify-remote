			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/like/like-outline",
					"TitleAlignment": "middle"
				},
				{
					"Image": "imgs/actions/like/like-filled",
					"TitleAlignment": "middle"
				}
			]
		},
		{
			"Name": "Set Volume",
			"UUID": "com.dekub.spicetify-remote.setvolume",
			"Icon": "imgs/actions/volume/volume-display",
			"Tooltip": "Sets Spotify volume to a specific level.",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "ui/set-volume-pi.html",
			"States": [
				{
					"Image": "imgs/transparent",
					"TitleAlignment": "middle",
					"FontSize": 18,
					"TitleColor": "#ffffff"
				}
			]
		}
	],
	"Category": "spicetify-remote",
	"CategoryIcon": "imgs/plugin/category-icon",
	"CodePath": "bin/plugin.js",
	"Description": "plugin",
	"Icon": "imgs/plugin/marketplace",
	"SDKVersion": 3,
	"Software": {
		"MinimumVersion": "6.9"
	},
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "12"
		},
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		}
	],
	"Nodejs": {
		"Version": "20",
		"Debug": "enabled"
	},
	"UUID": "com.dekub.spicetify-remote"
}