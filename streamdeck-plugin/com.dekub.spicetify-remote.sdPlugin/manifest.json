			],
			"States": [
				{
					"Image": "imgs/actions/repeat/repeat-off",
					"TitleAlignment": "middle"
				},
				{
					"Image": "imgs/actions/repeat/repeat-context",
					"TitleAlignment": "middle"
				},
				{
					"Image": "imgs/actions/repeat/repeat-track",
					"TitleAlignment": "middle"
				}
			]
		},
		{
			"Name": "Toggle Like",
			"UUID": "com.dekub.spicetify-remote.togglelike",
			"Icon": "imgs/actions/like/like-outline",
