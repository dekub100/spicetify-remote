			"Tooltip": "Plays the previous track in Spotify.",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/playback/playback-previous",
					"TitleAlignment": "middle"
				}
			]
		},
		{
			"Name": "Volume Up",
			"UUID": "com.dekub.spicetify-remote.volumeup",
