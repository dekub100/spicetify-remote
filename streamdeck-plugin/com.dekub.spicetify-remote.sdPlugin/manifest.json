			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/playback/playback-next",
					"TitleAlignment": "middle"
				}
			]
		},
		{
			"Name": "Previous Track",
			"UUID": "com.dekub.spicetify-remote.previoustrack",
