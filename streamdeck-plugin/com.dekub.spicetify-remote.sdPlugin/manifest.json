			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/shuffle/shuffle-off",
					"TitleAlignment": "middle"
				},
				{
					"Image": "imgs/actions/shuffle/shuffle-on",
					"TitleAlignment": "middle"
				}
			]
		},
		{
			"Name": "Toggle Repeat",
			"UUID": "com.dekub.spicetify-remote.togglerepeat",
