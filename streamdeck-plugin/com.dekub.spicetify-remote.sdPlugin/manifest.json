				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/playback/playback-play",
					"TitleAlignment": "middle"
				},
				{
					"Image": "imgs/actions/playback/playback-pause",
					"TitleAlignment": "middle"
				}
			]
		},
		{
			"Name": "Next Track",
			"UUID": "com.dekub.spicetify-remote.nexttrack",
			"Icon": "imgs/actions/playback/playback-next",
